# ═══════════════════════════════════════════════════════════════════════════════
# Foretyx Data Plane — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values:   cp .env.example .env

# ── LLM API ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
DEFAULT_LLM_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# ── Ollama (Phase 2 escalation) ───────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=foretyx-guard
OLLAMA_TIMEOUT_SECONDS=3

# ── Control Plane telemetry ───────────────────────────────────────────────────
CONTROL_PLANE_URL=http://localhost:8000
BRIDGE_TOKEN=

# ── SECURITY: Admin API Key (REQUIRED) ───────────────────────────────────────
# This key is required to access /v1/logs and /v1/metrics endpoints
# Use a secure, randomly generated token (minimum 32 characters)
ADMIN_API_KEY=your_secure_admin_api_key_min_32_chars_long

# ── SECURITY: Production HTTPS ────────────────────────────────────────────────
# Set to true in production to enforce HTTPS
REQUIRE_HTTPS=false

# ── SECURITY: CORS Configuration ─────────────────────────────────────────────
# Comma-separated list of allowed origins (NEVER use * in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=false

# ── SECURITY: Trusted Proxies ────────────────────────────────────────────────
# Comma-separated list of trusted proxy IPs for X-Forwarded-For validation
TRUSTED_PROXIES=127.0.0.1

# ── ML Guard thresholds ──────────────────────────────────────────────────────
ML_BLOCK_THRESHOLD=0.98
ML_ESCALATE_THRESHOLD=0.95

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Security ─────────────────────────────────────────────────────────────────
FAIL_BEHAVIOR=CLOSED
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Model paths ──────────────────────────────────────────────────────────────
ONNX_MODEL_PATH=models/ml_guard.onnx

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
