# ═══════════════════════════════════════════════════════════════════════════════
# Foretyx Data Plane — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values:   cp .env.example .env

# ── LLM API ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
DEFAULT_LLM_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# ── Ollama (Phase 2 escalation) ───────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=foretyx-guard
OLLAMA_TIMEOUT_SECONDS=3

# ── Control Plane telemetry ───────────────────────────────────────────────────
CONTROL_PLANE_URL=http://localhost:8000
BRIDGE_TOKEN=

# ── ML Guard thresholds ──────────────────────────────────────────────────────
ML_BLOCK_THRESHOLD=0.98
ML_ESCALATE_THRESHOLD=0.95

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Security ─────────────────────────────────────────────────────────────────
FAIL_BEHAVIOR=CLOSED
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Model paths ──────────────────────────────────────────────────────────────
ONNX_MODEL_PATH=models/ml_guard.onnx

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
