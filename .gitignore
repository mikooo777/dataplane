# ── Environment (CRITICAL — never commit secrets) ─────────────────────────────
.env

# ── ML Models (too large for git, ~256MB) ─────────────────────────────────────
models/*.onnx
models/*.onnx.data
models/*.bin
models/*.pt

# ── GGUF Models (too large for git, ~800MB) ───────────────────────────────────
*.gguf

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Databases (local runtime logs) ───────────────────────────────────────────
*.db
*.db-journal
*.sqlite3

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ───────────────────────────────────────────────────────────────────
.dockerignore

# ── Coverage / Testing ───────────────────────────────────────────────────────
htmlcov/
.coverage
.pytest_cache/
.tox/

# ── Test result artifacts ────────────────────────────────────────────────────
*_test_results*.json

# ── Review / audit documents (internal process artifacts) ────────────────────
SHIPPPPP.*
